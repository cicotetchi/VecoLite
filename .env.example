# Copier en .env pour le développement local

# Admin credentials (CHANGER en production !)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=votre-mot-de-passe-securise
ADMIN_TOKEN=votre-token-secret-long-et-aleatoire

# Base de données (laisser vide = SQLite /tmp sur Vercel)
# Pour la production, utiliser Turso ou Supabase :
